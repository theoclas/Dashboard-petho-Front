# =============================================
# Petho Dashboard - Variables de entorno
# =============================================
# Desarrollo: usa .env.local o define en el shell
# Producción: usa .env.production antes de npm run build
#
# VITE_API_URL - URL base de la API (sin trailing slash, incluye /api)
#   Desarrollo con Nest local: http://localhost:3001/api (debe coincidir con PORT del backend)
#   Solo nube: https://tu-dominio.com/api — si usas esto mientras corres Nest en PC, verás datos distintos.
#   Producción build: https://your-domain.com/api
# =============================================
VITE_API_URL=http://localhost:3001/api

# Mismo correo que MASTER_ADMIN_EMAIL en el backend (solo para mostrar/ocultar acciones del admin principal).
VITE_MASTER_ADMIN_EMAIL=

# La limpieza de tablas importadas usa la contraseña definida en el BACK como IMPORT_WIPE_SECRET
# (no va en el front; solo documentado aquí).
